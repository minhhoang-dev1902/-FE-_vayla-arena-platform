{
	"name": "vayla-arena-client",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"check:prod": "cross-env NEXT_PUBLIC_ENV=production biome check . --write --unsafe",
		"build:prod": "cross-env NEXT_PUBLIC_ENV=production next build",
		"start:prod": "cross-env NEXT_PUBLIC_ENV=production next start",
		"build": "npm run check:prod && npm run build:prod",
		"start": "npm run start:prod",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix",
		"prepare": "husky",
		"release": "standard-version && git push --follow-tags"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.100.5",
		"axios": "^1.15.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"embla-carousel-autoplay": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^0.563.0",
		"motion": "^12.38.0",
		"next": "16.1.6",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.74.0",
		"shadcn": "^4.2.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@commitlint/cli": "^20.4.0",
		"@commitlint/config-conventional": "^20.4.0",
		"@tailwindcss/postcss": "^4",
		"@tanstack/eslint-plugin-query": "^5.100.5",
		"@tanstack/react-query-devtools": "^5.100.5",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"cross-env": "^10.1.0",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"eslint-plugin-perfectionist": "^5.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"standard-version": "^9.5.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,jsx,mjs,cjs,ts,tsx,json,css,md,mdx}": [
			"biome check --write --unsafe --no-errors-on-unmatched"
		]
	},
	"engines": {
		"node": ">=20.0.0 <21.0.0",
		"npm": ">=10.0.0"
	}
}
